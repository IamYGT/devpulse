{
  "manifest_version": 3,
  "name": "DevPulse Tab Tracker",
  "description": "Tracks active browser tabs for DevPulse productivity tracker",
  "version": "1.0.0",
  "permissions": ["tabs", "activeTab", "alarms"],
  "host_permissions": ["http://localhost:19876/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
