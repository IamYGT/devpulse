{
  "name": "devpulse-code-tracker",
  "displayName": "DevPulse Code Tracker",
  "description": "Tracks VS Code activity for DevPulse productivity tracker",
  "version": "1.0.0",
  "publisher": "ygtlabs",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["*"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [{
      "command": "devpulse.showStatus",
      "title": "DevPulse: Show Status"
    }]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
